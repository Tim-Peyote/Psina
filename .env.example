# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/zalutka
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@db:5432/zalutka

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# LLM (OpenRouter)
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_FALLBACK_PROVIDER=mock
LLM_FALLBACK_MODEL=mock-v1

# Token budget (per day)
DAILY_TOKEN_BUDGET=100000

# Bot identity
BOT_NAME=Псина
BOT_ALIASES=["пес","пёс","песик","пёсик"]

# Bot behavior
BOT_MODE=observer  # observer | assistant | social | game_master
QUIET_HOURS_START=23
QUIET_HOURS_END=7

# Trigger system
TRIGGER_HIGH_THRESHOLD=0.7
TRIGGER_MEDIUM_THRESHOLD=0.3

# Session management
SESSION_TIMEOUT_SECONDS=180
SESSION_MAX_MESSAGES=8
MAX_SESSIONS_PER_CHAT=5

# Anti-chaos
ANTI_CHAOS_COOLDOWN=30
ANTI_CHAOS_MAX_PER_HOUR=20
ANTI_CHAOS_MAX_CONSECUTIVE=3

# Retrieval
MAX_CONTEXT_TOKENS=3000
MAX_MEMORY_ITEMS=10
EMBEDDING_DIMENSION=768

# Web search
WEB_SEARCH_PROVIDER=searxng
SEARXNG_URL=http://searxng:8080

# Censorship: strict | moderate | free
DEFAULT_CENSORSHIP_LEVEL=moderate

# Admin API
ADMIN_API_HOST=0.0.0.0
ADMIN_API_PORT=8000
ADMIN_API_SECRET=change_me_in_production
